# Groq
GROQ_API_KEY=your_groq_api_key_here

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Sheet must have 4 tabs: Enquiries, Complaints, Booking Requests, Other
# Each tab needs columns: Timestamp, Sender Name, Sender Email, Subject, Summary, Category

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# n8n Webhook
WEBHOOK_PATH=inbound-email
